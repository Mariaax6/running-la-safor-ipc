<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@/resources/estilos.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mapademo.controllers.LoginViewController">
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="header-bar">
            <Label text="Running la Safor" />
        </HBox>
    </top>
    <center>
        <StackPane styleClass="background-dark">
            <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="400" spacing="20.0" styleClass="card-white">
                <Label style="-fx-font-size: 22px; -fx-font-weight: bold;" text="Iniciar sesión" />
                <VBox alignment="CENTER_LEFT" spacing="8.0">
                    <Label text="Nickname" />
                    <TextField fx:id="nickField" promptText="Tu nickname" />
                </VBox>
                <VBox alignment="CENTER_LEFT" spacing="8.0">
                    <Label text="Contraseña" />
                    <PasswordField fx:id="passwordField" promptText="••••••••" />
                </VBox>
                <Button maxWidth="Infinity" onAction="#handleLogin" styleClass="button-primary" text="Entrar" />
                <Hyperlink onAction="#goToRegister" text="¿No tienes cuenta? Regístrate" />
            <Hyperlink onAction="#skipLogin" text="Saltar Login (testeo)" />
            </VBox>
        </StackPane>
    </center>
</BorderPane>

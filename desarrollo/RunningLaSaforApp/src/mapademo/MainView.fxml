<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="rootPane"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="mapademo.MainViewController">

    <top>
        <Label text="Running la Safor"
               style="-fx-font-size: 22px; -fx-padding: 15;" />
    </top>

    <left>
        <VBox spacing="10" style="-fx-padding: 15;">
            <Button text="Actividades" onAction="#mostrarActividades" />
            <Button text="Importar GPX" onAction="#mostrarActividades" />
            <Button text="Historial" />
            <Button text="Mapas" />
            <Button text="Perfil" />
            <Button text="Cerrar sesión" />
        </VBox>
    </left>

    <center>
        <Label text="Bienvenido a Running la Safor"
               style="-fx-font-size: 18px;" />
    </center>

</BorderPane>
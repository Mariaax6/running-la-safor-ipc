<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20" style="-fx-padding: 30;"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="mapademo.PerfilViewController">

    <Label style="-fx-font-size: 24px;" text="Perfil" />

    <VBox maxWidth="350" spacing="8">

        <Label style="-fx-font-weight: bold;" text="Datos personales">
            <font>
                <Font size="14.0" />
            </font>
        </Label>

        <Label text="Nickname" />
        <TextField fx:id="nicknameField" />

        <Label text="Email*" />
        <TextField fx:id="emailField" />
        <Label fx:id="emailError"
               text="usuario@dominio"
               textFill="red"
               visible="false"
               wrapText="true"/>

        <Label text="Contraseña*" />
        <PasswordField fx:id="passwordField" />
        <Label fx:id="passError"
               text="8-20 caracteres, con mayúscula, minúscula, número y símbolo"
               textFill="red"
               visible="false"
               wrapText="true"/>

        <Label text="Fecha de nacimiento*" />
        <DatePicker fx:id="fechaPicker" />
        <Label fx:id="fechaError"
               text="Debes tener más de 12 años"
               textFill="red"
               visible="false"
               wrapText="true"/>

    </VBox>

    <Separator maxWidth="350" />

    <VBox maxWidth="350" spacing="8">
        <Label style="-fx-font-weight: bold;" text="Avatar">
            <font>
                <Font size="14.0" />
            </font>
        </Label>
        <Button text="Seleccionar imagen" onAction="#seleccionarAvatar" />
        <Label fx:id="avatarLabel" text="Ningún archivo seleccionado" />
    </VBox>

    <HBox alignment="CENTER" spacing="10" style="-fx-padding: 20 0 0 0;">
        <Button fx:id="btnGuardar" text="Guardar cambios" onAction="#guardarCambios" />
        <Button fx:id="btnVolver" text="Volver" onAction="#volverMenu" />
    </HBox>

</VBox>
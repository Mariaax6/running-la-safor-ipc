<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" style="-fx-padding: 20;"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="mapademo.PerfilViewController">

    <Label text="Perfil de usuario" style="-fx-font-size: 22px;" />

    <TextField promptText="Email" />
    <PasswordField promptText="Nueva contraseña" />

    <Button text="Guardar cambios" onAction="#guardarCambios" />
    <Button fx:id="btnVolver" text="Volver" onAction="#volverMenu" />

</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="mapademo.controllers.PerfilViewController"
           style="-fx-background-color: transparent;">

    <ScrollPane fitToWidth="true"
                fitToHeight="true"
                hbarPolicy="NEVER"
                vbarPolicy="AS_NEEDED"
                style="-fx-background-color: transparent; -fx-background: transparent;">

        <StackPane alignment="TOP_CENTER"
                   style="-fx-background-color: transparent; -fx-padding: 30 0 30 0;">

            <VBox alignment="CENTER"
                  maxWidth="520"
                  spacing="16.0"
                  style="-fx-padding: 25 40 25 40;"
                  styleClass="card-white"
                  stylesheets="@/resources/estilos.css">

                <Label text="Modificar perfil"
                       style="-fx-font-size: 22px; -fx-font-weight: bold;" />

                <VBox spacing="4.0" maxWidth="340">
                    <Label text="Nickname" />
                    <TextField fx:id="nickField" editable="false" />
                </VBox>

                <VBox spacing="4.0" maxWidth="340">
                    <Label text="Correo electrónico" />
                    <TextField fx:id="emailField" />
                    <Label fx:id="emailError"
                           style="-fx-font-size: 11px; -fx-padding: 2 0 0 5;"
                           visible="false"
                           wrapText="true" />
                </VBox>

                <VBox spacing="4.0" maxWidth="340">
                    <Label text="Nueva contraseña" />
                    <PasswordField fx:id="passField"
                                   promptText="Dejar en blanco para mantener" />
                    <Label fx:id="passError"
                           style="-fx-font-size: 11px; -fx-padding: 2 0 0 5;"
                           visible="false"
                           wrapText="true" />
                </VBox>

                <VBox spacing="4.0" maxWidth="340">
                    <Label text="Fecha de nacimiento" />
                    <DatePicker fx:id="birthPicker"
                                maxWidth="220"
                                style="-fx-padding: 5;" />
                    <Label fx:id="fechaError"
                           style="-fx-font-size: 11px; -fx-padding: 2 0 0 5;"
                           visible="false"
                           wrapText="true" />
                </VBox>

                <Separator maxWidth="340"
                           opacity="1"
                           style="-fx-padding: 5 0;" />

                <HBox alignment="CENTER_LEFT"
                      spacing="10.0"
                      maxWidth="340">
                    <Button onAction="#chooseAvatar"
                            styleClass="button-secondary"
                            text="Cambiar avatar" />
                    <Label fx:id="avatarLabel"
                           style="-fx-text-fill: #86868b; -fx-font-style: italic;"
                           text="Sin avatar" />
                </HBox>

                <HBox alignment="CENTER"
                      spacing="10"
                      style="-fx-padding: 20 0 0 0;">
                    <Button fx:id="btnGuardar"
                            onAction="#saveProfile"
                            styleClass="button-primary"
                            text="Guardar cambios" />
                    <Button onAction="#goBack"
                            styleClass="button-secondary"
                            text="Volver" />
                </HBox>

            </VBox>

        </StackPane>

    </ScrollPane>

</StackPane>
<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="16.0" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="mapademo.controllers.MapManagementController"
      stylesheets="@../resources/estilos.css">
    <padding><Insets top="24.0" right="24.0" bottom="24.0" left="24.0"/></padding>
    <Label text="Gestión de mapas" styleClass="title"/>
    <Label text="Mapas disponibles"/>
    <ListView fx:id="allMapsList"/>
    <Label text="Mapas no usados (se pueden eliminar)"/>
    <ListView fx:id="unusedMapsList"/>
    <HBox spacing="12.0">
        <Button text="Añadir mapa" onAction="#addMap" styleClass="button-primary"/>
        <Button text="Eliminar seleccionado" onAction="#removeMap" styleClass="button-secondary"/>
    </HBox>
</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="mainPane" stylesheets="@/resources/estilos.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mapademo.controllers.MainViewController">
    <top>
        <AnchorPane prefHeight="50" styleClass="header-bar">
            <Label styleClass="header-title" text="Running la Safor" AnchorPane.leftAnchor="30" AnchorPane.topAnchor="10" />
            <MenuButton fx:id="userMenuButton" styleClass="user-menu-button" AnchorPane.bottomAnchor="5.0" AnchorPane.rightAnchor="30" AnchorPane.topAnchor="5" />
        </AnchorPane>
    </top>
    <left>
        <VBox prefWidth="220" styleClass="sidebar">
            <padding><Insets top="10" /></padding>
            <Button maxWidth="Infinity" onAction="#showActivities" text="📋  Mis Actividades" />
            <Button maxWidth="Infinity" onAction="#importActivity" text="📂  Importar GPX" />
            <Button maxWidth="Infinity" onAction="#showMapManagement" text="🗺️  Gestión Mapas" />
            <Button maxWidth="Infinity" onAction="#showProfile" text="👤  Perfil" />
            <Button maxWidth="Infinity" onAction="#showHistory" text="📊  Historial" />
        </VBox>
    </left>
    <center>
        <Label style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #333;" text="Bienvenido a Running la Safor" BorderPane.alignment="CENTER" />
    </center>
</BorderPane>
